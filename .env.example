# ---------------------------------------------------------------------------
# Voxinta — environment configuration
# Copy to `.env.local` and fill in. Never commit real secrets.
# Secrets must NOT use the NEXT_PUBLIC_ prefix (that inlines them client-side).
# ---------------------------------------------------------------------------

# --- Supabase --------------------------------------------------------------
# Project URL + anon key are safe to expose (RLS protects data).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key BYPASSES RLS. Server-only — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Site ---------------------------------------------------------------
# Absolute origin used to build Supabase auth email redirect links.
# Must be included in Supabase's redirect URL allow-list.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- LLM (server-side) -----------------------------------------------------
# Active LLM provider. One of: groq | openai | anthropic | gemini | ollama.
LLM_PROVIDER=groq
# Groq API key — https://console.groq.com/keys
GROQ_API_KEY=
# Optional overrides:
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Speech-to-Text (client-side selection) --------------------------------
# One of: browser | whisper-api | faster-whisper. Default: browser.
NEXT_PUBLIC_STT_PROVIDER=browser

# --- Text-to-Speech (client-side selection) --------------------------------
# One of: browser | elevenlabs | openai | piper. Default: browser.
NEXT_PUBLIC_TTS_PROVIDER=browser

# --- Embeddings (server-side) ----------------------------------------------
# One of: placeholder | openai | cohere | local. Default: openai.
# 1536 dimensions (text-embedding-3-small) to match document_chunks.embedding.
EMBEDDING_PROVIDER=openai
# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional overrides:
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1

# --- Settings: user-supplied API keys (server-side) -------------------------
# Master secret for encrypting BYO-provider API keys at rest (see
# features/settings). Generate one with: openssl rand -base64 32
API_KEY_ENCRYPTION_SECRET=
